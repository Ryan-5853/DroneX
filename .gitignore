# =============================================================================
# DroneX Project .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# MATLAB
# -----------------------------------------------------------------------------
*.asv
*.m~
*.autosave
matlab.prj
profiling/

# -----------------------------------------------------------------------------
# Simulink
# -----------------------------------------------------------------------------
slprj/
*.slxc
*.slx~
*.rpt
*.rtw
*.tmf
*.tlc
html/
*.sldd
*.slddc

# -----------------------------------------------------------------------------
# 仿真输出（大型数据文件，按需取消注释以纳入版本控制）
# -----------------------------------------------------------------------------
sim/data/results/*.mat
sim/data/results/*.csv
sim/data/results/*.log

# -----------------------------------------------------------------------------
# CAD / 机械设计（按工具选择性忽略）
# -----------------------------------------------------------------------------
# Fusion 360 本地缓存
*.f3d.cache/
*.f3z

# FreeCAD 备份
*.fcstd1
*.fcbak

# 通用 CAD 临时文件
*~
*.tmp
*.temp
*.bak
*.swp
*.swo

# -----------------------------------------------------------------------------
# 固件 / 嵌入式（firmware 子目录添加后生效）
# -----------------------------------------------------------------------------
# Build 输出
build/
Release/
*.o
*.obj
*.elf
*.bin
*.hex
*.map
*.lst

# STM32 / CubeIDE
.settings/
.cproject
.project
*.launch

# -----------------------------------------------------------------------------
# 操作系统
# -----------------------------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory

# -----------------------------------------------------------------------------
# IDE / 编辑器
# -----------------------------------------------------------------------------
# Visual Studio Code / Cursor（项目级，保留 .vscode 配置时删除下列行）
# .vscode/
# .cursor/

# JetBrains
.idea/
*.iml
*.ipr
*.iws

# -----------------------------------------------------------------------------
# 其他
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
.env
.env.local
.env.*.local
